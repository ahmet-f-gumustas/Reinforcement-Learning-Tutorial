<mujoco model="unitree_go2_quadruped">
  <!--
    Unitree Go2 Ilhamli Dort Bacakli Robot Modeli
    Unitree Go2 Inspired Quadruped Robot Model

    12 DOF: Her bacakta 3 eklem (hip abduction, hip flexion, knee)
    12 DOF: 3 joints per leg (hip abduction, hip flexion, knee)

    Bacak sirasi / Leg order:
      FL (Front Left), FR (Front Right), BL (Back Left), BR (Back Right)

    Actuator sirasi / Actuator order:
      [fl_abd, fl_hip, fl_knee, fr_abd, fr_hip, fr_knee,
       bl_abd, bl_hip, bl_knee, br_abd, br_hip, br_knee]

    Sensor:
      - 4x foot touch sensor
      - 1x torso gyro (3-axis)
      - 1x torso accelerometer (3-axis)
  -->

  <compiler angle="degree" coordinate="local" inertiafromgeom="true"/>
  <option integrator="RK4" timestep="0.002" gravity="0 0 -9.81"/>

  <default>
    <joint armature="0.01" damping="0.5" limited="true"/>
    <geom conaffinity="0" condim="3" density="1000" friction="1.0 0.5 0.5"
          margin="0.01" rgba="0.15 0.15 0.15 1"/>
    <motor ctrllimited="true" ctrlrange="-1.0 1.0"/>
  </default>

  <asset>
    <texture builtin="gradient" height="100" rgb1="0.6 0.8 1.0" rgb2="0.1 0.1 0.3"
             type="skybox" width="100"/>
    <texture builtin="checker" height="100" name="texplane"
             rgb1="0.2 0.3 0.4" rgb2="0.8 0.85 0.9" type="2d" width="100"/>
    <material name="MatPlane" reflectance="0.5" shininess="1"
              specular="1" texrepeat="60 60" texture="texplane"/>
  </asset>

  <worldbody>
    <light cutoff="100" diffuse="1 1 1" dir="0 0 -1.3"
           directional="true" pos="0 0 1.3" specular=".1 .1 .1"/>
    <geom conaffinity="1" condim="3" material="MatPlane" name="floor"
          pos="0 0 0" size="40 40 40" type="plane" rgba="0.8 0.9 0.8 1"/>

    <!-- ============================================ -->
    <!-- Ana Govde / Main Torso                       -->
    <!-- Go2 boyutlari: ~0.36 x 0.094 x 0.08 m       -->
    <!-- ============================================ -->
    <body name="torso" pos="0 0 0.35">
      <camera name="track" mode="trackcom" pos="0 -3 0.5" xyaxes="1 0 0 0 0 1"/>
      <joint name="root" type="free" armature="0" damping="0" limited="false"/>

      <geom name="torso_geom" type="box" size="0.18 0.047 0.04"
            pos="0 0 0" rgba="0.2 0.2 0.2 1" mass="5.0"/>

      <!-- IMU site on torso -->
      <site name="torso_imu" pos="0 0 0" size="0.01"/>

      <!-- ============================================ -->
      <!-- ON SOL BACAK / FRONT LEFT LEG (FL)           -->
      <!-- ============================================ -->
      <body name="fl_abd_link" pos="0.18 0.047 0">
        <!-- Hip Abduction: yana acilma / lateral swing -->
        <joint name="fl_abd_joint" type="hinge" axis="1 0 0"
               range="-25 25" pos="0 0 0"/>
        <geom name="fl_abd_geom" type="capsule"
              fromto="0 0 0 0 0.04 0" size="0.02"
              rgba="0.3 0.3 0.8 1"/>

        <body name="fl_hip_link" pos="0 0.04 0">
          <!-- Hip Flexion: on-arka sallanma / forward-backward swing -->
          <joint name="fl_hip_joint" type="hinge" axis="0 1 0"
                 range="-60 60" pos="0 0 0"/>
          <geom name="fl_upper_leg" type="capsule"
                fromto="0 0 0 0 0 -0.2" size="0.02"
                rgba="0.4 0.4 0.9 1"/>

          <body name="fl_knee_link" pos="0 0 -0.2">
            <!-- Knee: diz bukulme / knee flexion -->
            <joint name="fl_knee_joint" type="hinge" axis="0 1 0"
                   range="-145 -45" pos="0 0 0"/>
            <geom name="fl_lower_leg" type="capsule"
                  fromto="0 0 0 0 0 -0.2" size="0.015"
                  rgba="0.35 0.35 0.85 1"/>

            <!-- Foot contact -->
            <geom name="fl_foot" type="sphere" pos="0 0 -0.2" size="0.025"
                  rgba="0.6 0.6 0.6 1" conaffinity="1"/>
            <site name="fl_foot_site" pos="0 0 -0.2" size="0.025"/>
          </body>
        </body>
      </body>

      <!-- ============================================ -->
      <!-- ON SAG BACAK / FRONT RIGHT LEG (FR)          -->
      <!-- ============================================ -->
      <body name="fr_abd_link" pos="0.18 -0.047 0">
        <joint name="fr_abd_joint" type="hinge" axis="1 0 0"
               range="-25 25" pos="0 0 0"/>
        <geom name="fr_abd_geom" type="capsule"
              fromto="0 0 0 0 -0.04 0" size="0.02"
              rgba="0.3 0.3 0.8 1"/>

        <body name="fr_hip_link" pos="0 -0.04 0">
          <joint name="fr_hip_joint" type="hinge" axis="0 1 0"
                 range="-60 60" pos="0 0 0"/>
          <geom name="fr_upper_leg" type="capsule"
                fromto="0 0 0 0 0 -0.2" size="0.02"
                rgba="0.4 0.4 0.9 1"/>

          <body name="fr_knee_link" pos="0 0 -0.2">
            <joint name="fr_knee_joint" type="hinge" axis="0 1 0"
                   range="-145 -45" pos="0 0 0"/>
            <geom name="fr_lower_leg" type="capsule"
                  fromto="0 0 0 0 0 -0.2" size="0.015"
                  rgba="0.35 0.35 0.85 1"/>

            <geom name="fr_foot" type="sphere" pos="0 0 -0.2" size="0.025"
                  rgba="0.6 0.6 0.6 1" conaffinity="1"/>
            <site name="fr_foot_site" pos="0 0 -0.2" size="0.025"/>
          </body>
        </body>
      </body>

      <!-- ============================================ -->
      <!-- ARKA SOL BACAK / BACK LEFT LEG (BL)          -->
      <!-- ============================================ -->
      <body name="bl_abd_link" pos="-0.18 0.047 0">
        <joint name="bl_abd_joint" type="hinge" axis="1 0 0"
               range="-25 25" pos="0 0 0"/>
        <geom name="bl_abd_geom" type="capsule"
              fromto="0 0 0 0 0.04 0" size="0.02"
              rgba="0.3 0.3 0.8 1"/>

        <body name="bl_hip_link" pos="0 0.04 0">
          <joint name="bl_hip_joint" type="hinge" axis="0 1 0"
                 range="-60 60" pos="0 0 0"/>
          <geom name="bl_upper_leg" type="capsule"
                fromto="0 0 0 0 0 -0.2" size="0.02"
                rgba="0.4 0.4 0.9 1"/>

          <body name="bl_knee_link" pos="0 0 -0.2">
            <joint name="bl_knee_joint" type="hinge" axis="0 1 0"
                   range="-145 -45" pos="0 0 0"/>
            <geom name="bl_lower_leg" type="capsule"
                  fromto="0 0 0 0 0 -0.2" size="0.015"
                  rgba="0.35 0.35 0.85 1"/>

            <geom name="bl_foot" type="sphere" pos="0 0 -0.2" size="0.025"
                  rgba="0.6 0.6 0.6 1" conaffinity="1"/>
            <site name="bl_foot_site" pos="0 0 -0.2" size="0.025"/>
          </body>
        </body>
      </body>

      <!-- ============================================ -->
      <!-- ARKA SAG BACAK / BACK RIGHT LEG (BR)         -->
      <!-- ============================================ -->
      <body name="br_abd_link" pos="-0.18 -0.047 0">
        <joint name="br_abd_joint" type="hinge" axis="1 0 0"
               range="-25 25" pos="0 0 0"/>
        <geom name="br_abd_geom" type="capsule"
              fromto="0 0 0 0 -0.04 0" size="0.02"
              rgba="0.3 0.3 0.8 1"/>

        <body name="br_hip_link" pos="0 -0.04 0">
          <joint name="br_hip_joint" type="hinge" axis="0 1 0"
                 range="-60 60" pos="0 0 0"/>
          <geom name="br_upper_leg" type="capsule"
                fromto="0 0 0 0 0 -0.2" size="0.02"
                rgba="0.4 0.4 0.9 1"/>

          <body name="br_knee_link" pos="0 0 -0.2">
            <joint name="br_knee_joint" type="hinge" axis="0 1 0"
                   range="-145 -45" pos="0 0 0"/>
            <geom name="br_lower_leg" type="capsule"
                  fromto="0 0 0 0 0 -0.2" size="0.015"
                  rgba="0.35 0.35 0.85 1"/>

            <geom name="br_foot" type="sphere" pos="0 0 -0.2" size="0.025"
                  rgba="0.6 0.6 0.6 1" conaffinity="1"/>
            <site name="br_foot_site" pos="0 0 -0.2" size="0.025"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- ============================================ -->
  <!-- Motorlar / Actuators                         -->
  <!-- 12 motor: her bacakta 3 (abd, hip, knee)     -->
  <!-- ============================================ -->
  <actuator>
    <!-- Front Left -->
    <motor name="fl_abd_motor"  joint="fl_abd_joint"  gear="25"/>
    <motor name="fl_hip_motor"  joint="fl_hip_joint"  gear="25"/>
    <motor name="fl_knee_motor" joint="fl_knee_joint" gear="35"/>
    <!-- Front Right -->
    <motor name="fr_abd_motor"  joint="fr_abd_joint"  gear="25"/>
    <motor name="fr_hip_motor"  joint="fr_hip_joint"  gear="25"/>
    <motor name="fr_knee_motor" joint="fr_knee_joint" gear="35"/>
    <!-- Back Left -->
    <motor name="bl_abd_motor"  joint="bl_abd_joint"  gear="25"/>
    <motor name="bl_hip_motor"  joint="bl_hip_joint"  gear="25"/>
    <motor name="bl_knee_motor" joint="bl_knee_joint" gear="35"/>
    <!-- Back Right -->
    <motor name="br_abd_motor"  joint="br_abd_joint"  gear="25"/>
    <motor name="br_hip_motor"  joint="br_hip_joint"  gear="25"/>
    <motor name="br_knee_motor" joint="br_knee_joint" gear="35"/>
  </actuator>

  <!-- ============================================ -->
  <!-- Sensorler / Sensors                          -->
  <!-- ============================================ -->
  <sensor>
    <!-- Foot contact touch sensors -->
    <touch name="fl_foot_touch" site="fl_foot_site"/>
    <touch name="fr_foot_touch" site="fr_foot_site"/>
    <touch name="bl_foot_touch" site="bl_foot_site"/>
    <touch name="br_foot_touch" site="br_foot_site"/>
    <!-- IMU -->
    <gyro name="torso_gyro" site="torso_imu"/>
    <accelerometer name="torso_accel" site="torso_imu"/>
  </sensor>
</mujoco>
